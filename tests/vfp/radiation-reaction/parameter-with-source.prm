subsection Physical parameters
  set B0    = 1e+10
  set p_inj = 0.5e+07
  set sigma_p = 1e+04
  set injection_rate = 0.01
end
subsection Output
  set Base file name               = solution
  set Format                       = pvtu
  set Output frequency             = 20
  set Results folder               = ./results
  set Simulation identifier        = radiation-reaction-with-source
end
subsection VFP
  subsection Expansion
    set Expansion order = 1
  end
  subsection Finite element
    set Polynomial degree = 5
  end
  subsection Mesh
    set Grid type       = Hypercube
    set Number of cells = 256
    set Point 1         = 14.9141228466 # ln(3e6)
    set Point 2         = 15.761420707 # ln(7e6)
    subsection Boundary conditions
      set lower p = zero inflow
      set upper p = zero inflow 
    end
  end
  subsection Reference units
    set Charge = 1.602176634e-19 # Elementary charge.
    set Mass   = 9.1093837e-31   # Electron mass.
  end
  subsection Particle properties
    # Electron
    set Charge = -1
    set Mass   = 1.
  end
  subsection Time stepping
    set Final time     = 1e-5
    set Method         = LSERK4
    set Time step size = 0.5e-8
  end
end
